NODE_ENV=production
PORT=8787
# Generate exactly 32 random bytes encoded as 64 hexadecimal characters.
CONTENT_PROTECT_MASTER_KEY=replace_with_64_hex_characters
# External providers remain disabled until their sandbox accounts are approved.
PAYMENTS_MODE=unconfigured
TAKEDOWNS_MODE=sandbox
BIOMETRICS_ENABLED=false

# Configure all four values together. Partial configuration stops startup.
# Cloudflare R2 endpoints must use HTTPS and public bucket access must stay disabled.
OBJECT_STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
OBJECT_STORAGE_BUCKET=content-protect-private
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ACCESS_KEY_ID=replace_with_r2_access_key
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace_with_r2_secret_key
